# MongoDB Atlas connection string. When unset, the app falls back to a local
# JSON file (data/db.json locally; ephemeral /tmp on Vercel — data is LOST on
# every cold start, so production must always set this).
MONGODB_URI=

# Local server port (default 5000)
PORT=5000

# Extra CORS origins (your deployed storefront / dashboard URLs)
WEBSITE_URL=
DASHBOARD_URL=

# "true" to allow private-LAN origins through CORS in production (off by default)
ALLOW_LAN_ORIGINS=

# "true" to return 503 when MongoDB is unavailable instead of silently falling
# back to ephemeral JSON storage (also fail-fast at boot in production)
STRICT_DB=

# Override the JSON-fallback data directory (used by the test suite)
DATA_DIR=
